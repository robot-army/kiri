#!/usr/bin/env python3

import importlib.util
import json
import os
import subprocess
import sys
import tempfile
from datetime import datetime, timezone

import sexpdata


def _symbol_name(value):
    if isinstance(value, sexpdata.Symbol):
        return value.value()
    return value


def _to_string(value):
    value = _symbol_name(value)
    if value is None:
        return ""
    return str(value)


def _parse_at_node(node):
    if not isinstance(node, list) or len(node) < 3:
        return None
    if _symbol_name(node[0]) != "at":
        return None
    try:
        return [float(node[1]), float(node[2])]
    except Exception:
        return None


def _extract_symbol_info(symbol_node):
    if not isinstance(symbol_node, list) or not symbol_node:
        return None
    if _symbol_name(symbol_node[0]) != "symbol":
        return None

    ref = None
    value = ""
    lib_id = ""
    symbol_at = None
    ref_at = None

    for child in symbol_node:
        if not isinstance(child, list) or not child:
            continue

        child_name = _symbol_name(child[0])

        if child_name == "at":
            symbol_at = _parse_at_node(child)

        if child_name == "lib_id" and len(child) > 1:
            lib_id = _to_string(child[1]).strip('"')

        if child_name == "property" and len(child) > 2:
            prop_name = _to_string(child[1])
            prop_value = _to_string(child[2]).strip('"')

            if prop_name == "Reference":
                ref = prop_value
                for prop_child in child:
                    prop_at = _parse_at_node(prop_child)
                    if prop_at is not None:
                        ref_at = prop_at
                        break

            if prop_name == "Value":
                value = prop_value

    if not ref:
        return None

    return {
        "ref": ref,
        "lib_id": lib_id,
        "value": value,
        "at": ref_at or symbol_at,
    }


def _collect_pin_names(node, pin_map):
    if not isinstance(node, list) or not node:
        return

    if _symbol_name(node[0]) == "pin":
        pin_name = ""
        pin_number = ""

        for child in node:
            if not isinstance(child, list) or not child:
                continue

            child_name = _symbol_name(child[0])
            if child_name == "name" and len(child) > 1:
                pin_name = _to_string(child[1]).strip('"')
            if child_name == "number" and len(child) > 1:
                pin_number = _to_string(child[1]).strip('"')

        if pin_number:
            pin_map[pin_number] = pin_name or pin_number

    for child in node:
        if isinstance(child, list):
            _collect_pin_names(child, pin_map)


def _extract_lib_symbol_pin_maps(sch_data):
    pin_maps = {}

    for node in sch_data:
        if not isinstance(node, list) or not node:
            continue

        if _symbol_name(node[0]) != "lib_symbols":
            continue

        for child in node[1:]:
            if not isinstance(child, list) or len(child) < 2:
                continue
            if _symbol_name(child[0]) != "symbol":
                continue

            lib_symbol_name = _to_string(child[1]).strip('"')
            pin_map = {}
            _collect_pin_names(child, pin_map)
            if lib_symbol_name:
                pin_maps[lib_symbol_name] = pin_map

    return pin_maps


def _extract_refs_from_schematic(schematic_path, page_id, relpath):
    refs = {}

    with open(schematic_path, "r", encoding="utf-8") as f:
        sch_data = sexpdata.load(f)

    lib_symbol_pin_maps = _extract_lib_symbol_pin_maps(sch_data)

    for node in sch_data:
        info = _extract_symbol_info(node)
        if not info:
            continue

        refs[info["ref"]] = {
            "page": page_id,
            "schematic": relpath,
            "lib_id": info["lib_id"],
            "pins": lib_symbol_pin_maps.get(info["lib_id"], {}),
            "value": info["value"],
            "at": info["at"],
        }

    return refs


def _discover_schematic_pages(commit_dir):
    pages = []

    for root, _, files in os.walk(commit_dir):
        if "/_KIRI_" in root:
            continue

        for name in files:
            if not name.endswith(".kicad_sch"):
                continue

            abs_path = os.path.join(root, name)
            rel_path = os.path.relpath(abs_path, commit_dir)
            page_id = os.path.splitext(os.path.basename(name))[0]
            pages.append((page_id, rel_path, abs_path))

    pages.sort(key=lambda item: item[1])
    return pages


def _load_pages_from_sheets_file(commit_dir, sch_sheets_file):
    pages = []

    if not sch_sheets_file or not os.path.isfile(sch_sheets_file):
        return pages

    with open(sch_sheets_file, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue

            cols = line.split("|")
            page_id = cols[0].strip()
            relpath = cols[1].strip() if len(cols) > 1 else ""

            if not relpath:
                continue

            abs_path = os.path.join(commit_dir, relpath)
            if not os.path.isfile(abs_path):
                continue

            pages.append((page_id, relpath, abs_path))

    return pages


def _load_netdiff_module(kiri_root):
    netdiff_py = os.path.join(kiri_root, "submodules", "netdiff", "netdiff.py")
    if not os.path.exists(netdiff_py):
        raise FileNotFoundError(f"Missing netdiff module: {netdiff_py}")

    spec = importlib.util.spec_from_file_location("kiri_netdiff_module", netdiff_py)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


def _jsonable_nets(nets, refs):
    output = {}
    for net_name, members in nets.items():
        json_members = []
        for ref, pin in members:
            ref_key = str(ref)
            pin_key = str(pin)
            ref_info = refs.get(ref_key, {})
            pins = ref_info.get("pins") or {}

            member = {"ref": ref_key, "pin": pin_key}

            pin_name = pins.get(pin_key)
            if pin_name:
                member["pin_name"] = pin_name

            page = ref_info.get("page")
            if page:
                member["page"] = page

            schematic = ref_info.get("schematic")
            if schematic:
                member["schematic"] = schematic

            json_members.append(member)

        output[str(net_name)] = json_members
    return output


def _extract_nets_for_snapshot(netdiff_module, main_schematic):
    with tempfile.NamedTemporaryFile(mode="w", suffix=".net", delete=False) as temp_net:
        netlist_path = temp_net.name

    try:
        result = subprocess.run(
            ["kicad-cli", "sch", "export", "netlist", main_schematic, "--output", netlist_path],
            capture_output=True,
            text=True,
            timeout=120,
        )

        if result.returncode == 0 and os.path.exists(netlist_path) and os.path.getsize(netlist_path) > 0:
            netlist_data = netdiff_module.load_file(netlist_path)
            return netdiff_module.extract_nets(netlist_data, netlist_path)
    except Exception:
        pass
    finally:
        if os.path.exists(netlist_path):
            os.unlink(netlist_path)

    # Fallback mode when kicad-cli netlist export is unavailable
    main_data = netdiff_module.load_file(main_schematic)
    return netdiff_module.extract_nets(main_data, main_schematic)


def _main():
    if len(sys.argv) not in (4, 5):
        print(
            "Usage: kiri-netdiff-snapshot <commit_dir> <main_schematic> [sch_sheets_file] <output_json>",
            file=sys.stderr,
        )
        return 2

    commit_dir = os.path.abspath(sys.argv[1])
    main_schematic = os.path.abspath(sys.argv[2])

    if len(sys.argv) == 5:
        sch_sheets_file = os.path.abspath(sys.argv[3])
        output_json = os.path.abspath(sys.argv[4])
    else:
        sch_sheets_file = ""
        output_json = os.path.abspath(sys.argv[3])

    if not os.path.isdir(commit_dir):
        print(f"Commit directory not found: {commit_dir}", file=sys.stderr)
        return 1

    if not os.path.isfile(main_schematic):
        print(f"Main schematic not found: {main_schematic}", file=sys.stderr)
        return 1

    script_dir = os.path.dirname(os.path.abspath(__file__))
    kiri_root = os.path.dirname(script_dir)

    netdiff_module = _load_netdiff_module(kiri_root)

    nets = _extract_nets_for_snapshot(netdiff_module, main_schematic)

    refs = {}

    pages = _load_pages_from_sheets_file(commit_dir, sch_sheets_file)
    if not pages:
        pages = _discover_schematic_pages(commit_dir)

    for page_id, relpath, sch_path in pages:
        try:
            page_refs = _extract_refs_from_schematic(sch_path, page_id, relpath)
            refs.update(page_refs)
        except Exception:
            continue

    os.makedirs(os.path.dirname(output_json), exist_ok=True)

    snapshot = {
        "schema_version": 2,
        "generated_at_utc": datetime.now(timezone.utc).isoformat(),
        "main_schematic": os.path.relpath(main_schematic, commit_dir),
        "net_count": len(nets),
        "ref_count": len(refs),
        "nets": _jsonable_nets(nets, refs),
        "refs": refs,
    }

    with open(output_json, "w", encoding="utf-8") as f:
        json.dump(snapshot, f, indent=2, sort_keys=True)

    return 0


if __name__ == "__main__":
    raise SystemExit(_main())
